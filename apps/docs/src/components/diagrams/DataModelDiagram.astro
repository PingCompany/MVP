<div class="er-diagram">
  <div class="er-root">
    <div class="er-node er-root-node">
      <span class="er-node-icon">&#127968;</span>
      <span class="er-node-name">workspaces</span>
    </div>
    <div class="er-children">
      <div class="er-branch">
        <div class="er-node er-parent-node" tabindex="0">
          <span class="er-node-icon">&#128100;</span>
          <span class="er-node-name">users</span>
          <span class="er-fk">workspaceId</span>
        </div>
        <div class="er-sub-children">
          <div class="er-leaf"><span class="er-dot"></span>channelMembers <span class="er-fk">userId</span></div>
          <div class="er-leaf"><span class="er-dot"></span>directConversationMembers <span class="er-fk">userId</span></div>
          <div class="er-leaf"><span class="er-dot"></span>inboxSummaries <span class="er-fk">userId</span></div>
          <div class="er-leaf"><span class="er-dot"></span>proactiveAlerts <span class="er-fk">userId</span></div>
          <div class="er-leaf"><span class="er-dot"></span>drafts <span class="er-fk">userId</span></div>
          <div class="er-leaf"><span class="er-dot"></span>sessions <span class="er-fk">userId</span></div>
          <div class="er-leaf"><span class="er-dot"></span>reactions <span class="er-fk">userId</span></div>
          <div class="er-leaf"><span class="er-dot"></span>typingIndicators <span class="er-fk">userId</span></div>
        </div>
      </div>

      <div class="er-branch">
        <div class="er-node er-parent-node" tabindex="0">
          <span class="er-node-icon">&#128172;</span>
          <span class="er-node-name">channels</span>
          <span class="er-fk">workspaceId</span>
        </div>
        <div class="er-sub-children">
          <div class="er-leaf"><span class="er-dot"></span>messages <span class="er-fk">channelId</span></div>
          <div class="er-leaf"><span class="er-dot"></span>channelMembers <span class="er-fk">channelId</span></div>
          <div class="er-leaf"><span class="er-dot"></span>typingIndicators <span class="er-fk">channelId</span></div>
        </div>
      </div>

      <div class="er-branch">
        <div class="er-node er-parent-node" tabindex="0">
          <span class="er-node-icon">&#128233;</span>
          <span class="er-node-name">directConversations</span>
          <span class="er-fk">workspaceId</span>
        </div>
        <div class="er-sub-children">
          <div class="er-leaf"><span class="er-dot"></span>directMessages <span class="er-fk">conversationId</span></div>
          <div class="er-leaf"><span class="er-dot"></span>directConversationMembers <span class="er-fk">conversationId</span></div>
        </div>
      </div>

      <div class="er-branch">
        <div class="er-node er-parent-node single" tabindex="0">
          <span class="er-node-icon">&#128279;</span>
          <span class="er-node-name">integrationObjects</span>
          <span class="er-fk">workspaceId</span>
        </div>
      </div>

      <div class="er-branch">
        <div class="er-node er-parent-node single" tabindex="0">
          <span class="er-node-icon">&#9889;</span>
          <span class="er-node-name">proactiveAlerts</span>
          <span class="er-fk">workspaceId</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .er-diagram {
    margin: 1.5rem 0;
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    overflow-x: auto;
  }

  .er-root-node {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--ping-accent);
    color: #fff;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .er-root-node .er-node-icon {
    font-size: 1rem;
  }

  .er-children {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-left: 1.5rem;
    border-left: 2px solid var(--ping-border);
  }

  .er-branch {
    position: relative;
  }

  .er-parent-node {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--ping-surface);
    border: 1px solid var(--ping-border);
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ping-text);
    cursor: default;
    transition: all 0.15s ease;
  }

  .er-parent-node:hover {
    border-color: var(--ping-accent);
    box-shadow: 0 2px 8px rgba(94, 106, 210, 0.1);
  }

  .er-parent-node .er-node-icon {
    font-size: 0.875rem;
  }

  .er-fk {
    font-size: 0.625rem;
    font-weight: 400;
    color: var(--ping-text-muted);
    background: var(--ping-surface-raised);
    padding: 0.0625rem 0.375rem;
    border-radius: 999px;
    border: 1px solid var(--ping-border);
  }

  .er-sub-children {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding-left: 1.5rem;
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
    border-left: 1px dashed var(--ping-border);
  }

  .er-leaf {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--ping-text-muted);
    padding: 0.125rem 0;
    transition: color 0.15s;
  }

  .er-leaf:hover {
    color: var(--ping-text);
  }

  .er-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--ping-border);
    flex-shrink: 0;
  }

  .er-leaf:hover .er-dot {
    background: var(--ping-accent);
  }
</style>
