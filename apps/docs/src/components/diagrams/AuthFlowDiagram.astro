---
---

<div class="auth-flow">
  <div class="auth-flow-lanes">
    <div class="auth-lane-header">User</div>
    <div class="auth-lane-header">Next.js</div>
    <div class="auth-lane-header">WorkOS</div>
    <div class="auth-lane-header">Convex</div>
  </div>

  <div class="auth-flow-step" data-step="1">
    <div class="auth-step-number">1</div>
    <div class="auth-step-content">
      <div class="auth-step-title">Login</div>
      <div class="auth-step-lanes">
        <div class="auth-lane active">Click Login</div>
        <div class="auth-lane active">Redirect to WorkOS</div>
        <div class="auth-lane active">OAuth/SSO provider</div>
        <div class="auth-lane"></div>
      </div>
    </div>
  </div>

  <div class="auth-flow-step" data-step="2">
    <div class="auth-step-number">2</div>
    <div class="auth-step-content">
      <div class="auth-step-title">Callback</div>
      <div class="auth-step-lanes">
        <div class="auth-lane"></div>
        <div class="auth-lane active">/callback receives token</div>
        <div class="auth-lane active">JWT + user info</div>
        <div class="auth-lane"></div>
      </div>
    </div>
  </div>

  <div class="auth-flow-step" data-step="3">
    <div class="auth-step-number">3</div>
    <div class="auth-step-content">
      <div class="auth-step-title">API Calls</div>
      <div class="auth-step-lanes">
        <div class="auth-lane"></div>
        <div class="auth-lane active">Include JWT in Convex client</div>
        <div class="auth-lane"></div>
        <div class="auth-lane active">Verify JWT via JWKS</div>
      </div>
    </div>
  </div>

  <div class="auth-flow-step" data-step="4">
    <div class="auth-step-number">4</div>
    <div class="auth-step-content">
      <div class="auth-step-title">Authorized</div>
      <div class="auth-step-lanes">
        <div class="auth-lane active">See data</div>
        <div class="auth-lane active">Real-time updates</div>
        <div class="auth-lane"></div>
        <div class="auth-lane active">Function executes</div>
      </div>
    </div>
  </div>
</div>

<style>
  .auth-flow {
    margin: 1.5rem 0;
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    border-radius: 0.75rem;
    padding: 1rem;
    overflow-x: auto;
  }

  .auth-flow-lanes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--ping-border);
    margin-bottom: 0.5rem;
  }

  .auth-lane-header {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ping-text-muted);
    text-align: center;
  }

  .auth-flow-step {
    display: flex;
    gap: 0.75rem;
    padding: 0.625rem 0;
    transition: all 0.15s ease;
    border-radius: 0.375rem;
    cursor: default;
  }

  .auth-flow-step:hover {
    background: var(--ping-surface);
  }

  .auth-step-number {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    background: var(--sl-color-accent-low);
    color: var(--ping-accent);
    font-size: 0.6875rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1rem;
  }

  .auth-flow-step:hover .auth-step-number {
    background: var(--ping-accent);
    color: #fff;
  }

  .auth-step-content {
    flex: 1;
    min-width: 0;
  }

  .auth-step-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ping-text);
    margin-bottom: 0.375rem;
  }

  .auth-step-lanes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
  }

  .auth-lane {
    font-size: 0.75rem;
    color: var(--ping-text-muted);
    text-align: center;
    padding: 0.375rem 0.25rem;
    border-radius: 0.25rem;
    min-height: 1.5rem;
  }

  .auth-lane.active {
    background: var(--ping-surface);
    border: 1px solid var(--ping-border);
  }

  .auth-flow-step:hover .auth-lane.active {
    border-color: var(--ping-accent);
  }
</style>
