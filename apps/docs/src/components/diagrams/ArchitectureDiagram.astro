---
---

<div class="arch-diagram">
  <div class="arch-header">PING Platform</div>
  <div class="arch-columns">
    <div class="arch-box" data-layer="frontend">
      <div class="arch-box-title">Next.js 15</div>
      <div class="arch-box-subtitle">App Router</div>
      <ul class="arch-box-list">
        <li>React 19 UI</li>
        <li>Tailwind CSS</li>
        <li>Radix UI</li>
        <li>cmdk palette</li>
      </ul>
    </div>
    <div class="arch-connector">
      <div class="arch-connector-line"></div>
      <span class="arch-connector-label">WebSockets</span>
    </div>
    <div class="arch-box" data-layer="backend">
      <div class="arch-box-title">Convex Backend</div>
      <div class="arch-box-subtitle">Serverless</div>
      <ul class="arch-box-list">
        <li>Real-time DB</li>
        <li>Mutations</li>
        <li>Queries</li>
        <li>Actions</li>
        <li>CRON jobs</li>
      </ul>
    </div>
    <div class="arch-connector">
      <div class="arch-connector-line"></div>
      <span class="arch-connector-label">Webhooks / API</span>
    </div>
    <div class="arch-box" data-layer="external">
      <div class="arch-box-title">External Services</div>
      <div class="arch-box-subtitle">Integrations</div>
      <ul class="arch-box-list">
        <li>WorkOS</li>
        <li>OpenAI</li>
        <li>GitHub</li>
        <li>Linear</li>
        <li>Graphiti</li>
      </ul>
    </div>
  </div>
</div>

<style>
  .arch-diagram {
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .arch-header {
    text-align: center;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ping-text-muted);
    margin-bottom: 1.25rem;
  }

  .arch-columns {
    display: flex;
    align-items: stretch;
    gap: 0;
    justify-content: center;
  }

  .arch-box {
    flex: 1;
    max-width: 12rem;
    background: var(--ping-surface);
    border: 1px solid var(--ping-border);
    border-radius: 0.5rem;
    padding: 1rem;
    transition: all 0.2s ease;
    cursor: default;
  }

  .arch-box:hover {
    border-color: var(--ping-accent);
    box-shadow: 0 0 0 1px var(--ping-accent), 0 4px 12px rgba(94, 106, 210, 0.15);
    transform: translateY(-2px);
  }

  .arch-box[data-layer="frontend"]:hover { border-color: #3b82f6; box-shadow: 0 0 0 1px #3b82f6, 0 4px 12px rgba(59, 130, 246, 0.15); }
  .arch-box[data-layer="backend"]:hover { border-color: #8b5cf6; box-shadow: 0 0 0 1px #8b5cf6, 0 4px 12px rgba(139, 92, 246, 0.15); }
  .arch-box[data-layer="external"]:hover { border-color: #f59e0b; box-shadow: 0 0 0 1px #f59e0b, 0 4px 12px rgba(245, 158, 11, 0.15); }

  .arch-box-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ping-text);
    margin-bottom: 0.125rem;
  }

  .arch-box-subtitle {
    font-size: 0.6875rem;
    color: var(--ping-text-muted);
    margin-bottom: 0.75rem;
  }

  .arch-box-list {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.8125rem;
    color: var(--ping-text-muted);
  }

  .arch-box-list li {
    padding: 0.1875rem 0;
    padding-left: 0.75rem;
    position: relative;
  }

  .arch-box-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--ping-border);
    transform: translateY(-50%);
  }

  .arch-box:hover .arch-box-list li::before {
    background: var(--ping-accent);
  }

  .arch-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 4rem;
    flex-shrink: 0;
  }

  .arch-connector-line {
    width: 100%;
    height: 2px;
    background: var(--ping-border);
    position: relative;
  }

  .arch-connector-line::before,
  .arch-connector-line::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 6px;
    height: 6px;
    border: 2px solid var(--ping-border);
    border-radius: 50%;
    background: var(--ping-surface-raised);
    transform: translateY(-50%);
  }

  .arch-connector-line::before { left: -3px; }
  .arch-connector-line::after { right: -3px; }

  .arch-connector-label {
    font-size: 0.625rem;
    color: var(--ping-text-muted);
    margin-top: 0.375rem;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .arch-columns {
      flex-direction: column;
      gap: 0.5rem;
    }
    .arch-box { max-width: none; }
    .arch-connector {
      width: auto;
      height: 2rem;
      flex-direction: row;
      gap: 0.5rem;
    }
    .arch-connector-line {
      width: 2px;
      height: 100%;
    }
    .arch-connector-line::before { left: 50%; top: -3px; transform: translateX(-50%); }
    .arch-connector-line::after { right: auto; left: 50%; top: auto; bottom: -3px; transform: translateX(-50%); }
  }
</style>
