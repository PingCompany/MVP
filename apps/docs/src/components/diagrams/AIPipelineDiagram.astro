---
---

<div class="pipeline-diagram">
  <div class="pipeline-trigger">
    <div class="pipeline-trigger-dot"></div>
    <span>Message Written</span>
  </div>

  <div class="pipeline-branches">
    <div class="pipeline-branch" data-branch="inbox">
      <div class="pipeline-branch-header">
        <span class="pipeline-icon">&#9993;</span>
        <span>Inbox Summary</span>
      </div>
      <div class="pipeline-branch-body">
        <div class="pipeline-detail">
          <strong>Eisenhower Matrix Ranking</strong>
          <ul>
            <li><span class="dot urgent-important"></span>Urgent + Important</li>
            <li><span class="dot important"></span>Important</li>
            <li><span class="dot urgent"></span>Urgent</li>
            <li><span class="dot fyi"></span>FYI</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="pipeline-branch" data-branch="alerts">
      <div class="pipeline-branch-header">
        <span class="pipeline-icon">&#9889;</span>
        <span>Proactive Alerts</span>
      </div>
      <div class="pipeline-branch-body">
        <div class="pipeline-detail">
          <strong>Alert Types</strong>
          <ul>
            <li>Unanswered question</li>
            <li>PR review nudge</li>
            <li>Incident routing</li>
            <li>Blocked task</li>
            <li>Fact check</li>
            <li>Cross-team sync</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="pipeline-branch" data-branch="graph">
      <div class="pipeline-branch-header">
        <span class="pipeline-icon">&#128300;</span>
        <span>Knowledge Graph</span>
      </div>
      <div class="pipeline-branch-body">
        <div class="pipeline-detail">
          <strong>Graphiti Temporal Graph</strong>
          <ul>
            <li>Fact checking</li>
            <li>Context sync</li>
            <li>@KnowledgeBot</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="pipeline-result">
    <div class="pipeline-result-dot"></div>
    <span>Results written to DB &mdash; real-time push to UI</span>
  </div>
</div>

<style>
  .pipeline-diagram {
    margin: 1.5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .pipeline-trigger,
  .pipeline-result {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    border-radius: 999px;
    padding: 0.5rem 1.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ping-text);
  }

  .pipeline-trigger-dot,
  .pipeline-result-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ping-accent);
  }

  .pipeline-branches {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    width: 100%;
    padding: 1.5rem 0;
    position: relative;
  }

  .pipeline-branches::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    width: 1px;
    height: 1.5rem;
    background: var(--ping-border);
  }

  .pipeline-branches::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 1px;
    height: 1.5rem;
    background: var(--ping-border);
  }

  .pipeline-branch {
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    border-radius: 0.5rem;
    overflow: hidden;
    transition: all 0.2s ease;
    cursor: default;
  }

  .pipeline-branch:hover {
    border-color: var(--ping-accent);
    box-shadow: 0 4px 12px rgba(94, 106, 210, 0.12);
    transform: translateY(-2px);
  }

  .pipeline-branch[data-branch="inbox"]:hover { border-color: #3b82f6; }
  .pipeline-branch[data-branch="alerts"]:hover { border-color: #f59e0b; }
  .pipeline-branch[data-branch="graph"]:hover { border-color: #10b981; }

  .pipeline-branch-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ping-text);
    border-bottom: 1px solid var(--ping-border);
    background: var(--ping-surface);
  }

  .pipeline-icon {
    font-size: 1rem;
  }

  .pipeline-branch-body {
    padding: 0.75rem;
  }

  .pipeline-detail strong {
    display: block;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ping-text-muted);
    margin-bottom: 0.375rem;
  }

  .pipeline-detail ul {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.8125rem;
    color: var(--ping-text-muted);
  }

  .pipeline-detail ul li {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.125rem 0;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot.urgent-important { background: #ef4444; }
  .dot.important { background: #f59e0b; }
  .dot.urgent { background: #3b82f6; }
  .dot.fyi { background: #6b7280; }

  @media (max-width: 640px) {
    .pipeline-branches {
      grid-template-columns: 1fr;
    }
  }
</style>
